{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Grpc": "Information"
    }
  },
  "GrpcServer": {
    "Port": 50051,
    "EnableReflection": true,
    "EnableDetailedErrors": false,
    "MaxReceiveMessageSize": 16777216,
    "MaxSendMessageSize": 16777216,
    "RequireAuthentication": false,
    "ApiKeys": []
  },
  "Database": {
    "Provider": "SQLite",
    "ConnectionString": "Data Source=cascade.db",
    "AutoMigrate": true
  }
}

