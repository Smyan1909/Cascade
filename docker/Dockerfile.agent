# Python Agent Dockerfile
FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements first for caching
COPY python/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy proto files and generate Python code
COPY protos/ ./protos/
RUN python -m grpc_tools.protoc \
    -I./protos \
    --python_out=./cascade_agent/grpc_client/generated \
    --grpc_python_out=./cascade_agent/grpc_client/generated \
    ./protos/*.proto || true

# Copy source code
COPY python/cascade_agent/ ./cascade_agent/
COPY python/pyproject.toml .

# Install package
RUN pip install -e .

# Configuration
ENV CASCADE_SERVER_HOST=server
ENV CASCADE_SERVER_PORT=50051

# Entry point
ENTRYPOINT ["python", "-m", "cascade_agent"]


